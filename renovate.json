{
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "ignoreTests": false,
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "replace",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 9am on monday"
    ]
  },
  "packageRules": [
    {
      "description": "Automerge safe npm devDependency updates after CI passes",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require review for runtime dependency updates",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "dependencies"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge major updates",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "reviewers": [
    "tj2904"
  ],
  "schedule": [
    "before 9am"
  ]
}
